# =============================================================================
# gsforge .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# Distribution / packaging
.Python
build/
dist/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST
wheels/
pip-wheel-metadata/
share/python-wheels/

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.conda/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
htmlcov/

# mypy / ruff / pyright
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
pyrightconfig.json

# Jupyter
.ipynb_checkpoints
*.ipynb

# ---------------------------------------------------------------------------
# gsforge project data — never commit large binary assets
# ---------------------------------------------------------------------------

# Project directories (the whole point is they're self-contained on disk)
*.gsproject/

# Extracted frames — can be hundreds of MB
preprocess/

# COLMAP databases and sparse models
sfm/

# Trained models and point clouds
models/
*.ply
*.ckpt
*.pth

# Preview renders
renders/

# Log files
logs/
*.log

# Exported COLMAP folders
export_colmap/

# ---------------------------------------------------------------------------
# Test data — keep the small test video, ignore large outputs
# ---------------------------------------------------------------------------
# Keep: tests/test_data/ignatius.mp4 (small reference video)
# Ignore: any generated test project directories
tests/test_data/*.gsproject/
tests/output/

# ---------------------------------------------------------------------------
# OS / editor
# ---------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# VSCode
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains IDEs
.idea/
*.iml
*.iws

# ---------------------------------------------------------------------------
# COLMAP / FFmpeg binaries (project-local installs)
# ---------------------------------------------------------------------------
# Users may drop a portable COLMAP build into ./bin/ — don't commit it
bin/
!bin/.gitkeep

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.tmp
*.bak
*.swp
*.swo
.env.local
.env.*.local

tests/test_data/*.mp4
*.mp4
tests/test_data/*.mov

# pixi environments
.pixi/*
!.pixi/config.toml
